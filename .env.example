# Resend configuration for the /api/contact serverless function.
# Copy this file to `.env` for local development (used by `vercel dev`)
# and set the same variables in your Vercel project settings for production.

# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address, e.g. "Darkbloom Digital <hello@darkbloomdigital.com>".
# Must be a domain/address verified in your Resend account.
RESEND_FROM_EMAIL=
